REDIS_URL=rediss://:your-upstash-password@your-upstash-host.upstash.io:6379

# ── watsonx.ai authentication ─────────────────────────────────────
# PUBLIC IBM Cloud (ml.cloud.ibm.com) — use IBM Cloud IAM API key:
#   WATSONX_API_KEY=<40-char alphanumeric key from cloud.ibm.com/iam/apikeys>
#   WATSONX_URL=https://us-south.ml.cloud.ibm.com   (or ca-tor, eu-de, etc.)
#   Leave WATSONX_CPD_URL empty.
#
# CLOUD PAK FOR DATA (*.dai.cloud.ibm.com) — use CPD user API key:
#   WATSONX_API_KEY=<CPD user API key from CPD Settings → Profile → API key>
#   WATSONX_CPD_URL=https://ca-tor.dai.cloud.ibm.com   (your CPD hostname)
#   WATSONX_URL=https://ca-tor.dai.cloud.ibm.com        (same host for ML API)
#   Leave WATSONX_CPD_URL set so the CPD auth path is used.

WATSONX_API_KEY=your-watsonx-api-key
WATSONX_PROJECT_ID=your-watsonx-project-id
WATSONX_URL=https://ca-tor.ml.cloud.ibm.com
WATSONX_CPD_URL=

GOOGLE_AI_API_KEY=your-google-ai-studio-api-key

VERCEL_BLOB_TOKEN=your-vercel-blob-read-write-token

# ── CORS configuration ────────────────────────────────────────────
# ALLOWED_ORIGIN   — single production origin (e.g. https://nomvox.vercel.app)
# ALLOWED_ORIGINS  — comma-separated list (e.g. https://nomvox.app,https://nomvox.vercel.app)
# CORS_WILDCARD    — set to "true" to allow all origins (public API mode only)
ALLOWED_ORIGIN=http://localhost:3000
ALLOWED_ORIGINS=
CORS_WILDCARD=

PORT=8080
